---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer';
import AboutHero from '../components/AboutHero';
import OurMission from '../components/OurMission';
import CoreValuesGrid from '../components/CoreValuesGrid';
import OurApproach from '../components/OurApproach';
import WhoWeServe from '../components/WhoWeServe';
import AboutPageCta from '../components/AboutPageCta';

import siteConfig from '../../siteConfig.json';
import cloudflareConfig from '../../cloudflareConfig.json';
const { global, pages } = siteConfig.site;
const pageData = pages.about;
const seo = { title: pageData.seo.title, metaDescription: pageData.seo.metaDescription };
---

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": seo.title,
  "description": seo.metaDescription
})}></script>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `https://${cloudflareConfig.domain || 'placeholder.com'}/` },
    { "@type": "ListItem", "position": 2, "name": "About", "item": `https://${cloudflareConfig.domain || 'placeholder.com'}/about` }
  ]
})}></script>

<Layout seo={seo} canonicalPath="/about">
  <Header navigation={global.navigation} branding={global.branding} />
  <main>
    <AboutHero data={pageData.sections.aboutHero} client:load />
    <OurMission data={pageData.sections.ourMission} client:load />
    <CoreValuesGrid data={pageData.sections.coreValuesGrid} client:load />
    <OurApproach data={pageData.sections.ourApproach} client:load />
    <WhoWeServe data={pageData.sections.whoWeServe} client:load />
    <AboutPageCta data={pageData.sections.aboutPageCta} client:load />
  </main>
  <Footer footer={global.footer} />
</Layout>
