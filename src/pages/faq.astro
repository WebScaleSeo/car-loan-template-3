---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer';
import FaqHero from '../components/FaqHero';
import GeneralLoanFaq from '../components/GeneralLoanFaq';
import ApplicationProcessFaq from '../components/ApplicationProcessFaq';
import RefinancingFaq from '../components/RefinancingFaq';
import CreditAndEligibilityFaq from '../components/CreditAndEligibilityFaq';
import FaqBottomCta from '../components/FaqBottomCta';

import siteConfig from '../../siteConfig.json';
import cloudflareConfig from '../../cloudflareConfig.json';
const { global, pages } = siteConfig.site;
const pageData = pages.faq;
const seo = { title: pageData.seo.title, metaDescription: pageData.seo.metaDescription };
---

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": seo.title,
  "description": seo.metaDescription
})}></script>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `https://${cloudflareConfig.domain || 'placeholder.com'}/` },
    { "@type": "ListItem", "position": 2, "name": "Faq", "item": `https://${cloudflareConfig.domain || 'placeholder.com'}/faq` }
  ]
})}></script>

<Layout seo={seo} canonicalPath="/faq">
  <Header navigation={global.navigation} branding={global.branding} />
  <main>
    <FaqHero data={pageData.sections.faqHero} client:load />
    <GeneralLoanFaq data={pageData.sections.generalLoanFaq} client:load />
    <ApplicationProcessFaq data={pageData.sections.applicationProcessFaq} client:load />
    <RefinancingFaq data={pageData.sections.refinancingFaq} client:load />
    <CreditAndEligibilityFaq data={pageData.sections.creditAndEligibilityFaq} client:load />
    <FaqBottomCta data={pageData.sections.faqBottomCta} client:load />
  </main>
  <Footer footer={global.footer} />
</Layout>
