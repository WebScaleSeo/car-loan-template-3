        "metaDescription": "Reach out to DriveRate Auto Loans to discuss your car financing needs. Fill out our contact form and a member of our team will get back to you promptly."
      },
      "componentOrder": [
        "contactHero",
        "contactForm",
        "whatToExpect",
        "contactFaqPreview",
        "contactClosingCta"
      ],
      "componentDefinitions": {
        "contactHero": {
          "purpose": "Introduces the contact page with a welcoming headline and brief description of what happens after contacting DriveRate.",
          "dataSchema": {
            "type": "object",
            "properties": {
              "headline": {
                "type": "string",
                "description": "Contact page heading, e.g. 'Let's Talk About Your Car Loan'"
              },
              "subheadline": {
                "type": "string",
                "description": "1-2 sentences about getting in touch and what to expect"
              }
            },
            "required": [
              "headline",
              "subheadline"
            ]
          }
        },
        "contactForm": {
          "purpose": "The main contact form allowing visitors to submit their name, email, phone, and a message to begin the car loan conversation.",
          "dataSchema": {
            "type": "object",
            "properties": {
              "formTitle": {
                "type": "string",
                "description": "Form heading, e.g. 'Send Us a Message'"
              },
              "formDescription": {
                "type": "string",
                "description": "Brief instruction text above the form"
              },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "fieldName": {
                      "type": "string",
                      "description": "Field identifier, e.g. 'fullName', 'email', 'phone', 'message'"
                    },
                    "label": {
                      "type": "string",
                      "description": "Field label displayed to user"
                    },
                    "type": {
                      "type": "string",
                      "description": "Input type: text, email, tel, textarea"
                    },
                    "placeholder": {
                      "type": "string",
                      "description": "Placeholder text"
                    },
                    "required": {
                      "type": "boolean",
                      "description": "Whether field is required"
                    }
                  },
                  "required": [
                    "fieldName",
                    "label",
                    "type",
                    "placeholder",
                    "required"
                  ]
                }
              },
              "submitButtonLabel": {
                "type": "string",
                "description": "Submit button text, e.g. 'Send Message'"
              }
            },
            "required": [
              "formTitle",
              "formDescription",
              "fields",
              "submitButtonLabel"
            ]
          }
        },
        "whatToExpect": {
          "purpose": "Explains what happens after a visitor submits the form — sets expectations for response time and next steps.",
          "dataSchema": {
            "type": "object",
            "properties": {
              "sectionTitle": {
                "type": "string",
                "description": "Heading like 'What Happens Next?'"
              },
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "stepNumber": {
                      "type": "string",
                      "description": "Step number"
                    },
                    "title": {
                      "type": "string",
                      "description": "Step title"
                    },
                    "description": {
                      "type": "string",
                      "description": "1-2 sentence explanation"
                    }
                  },
                  "required": [
                    "stepNumber",
                    "title",
                    "description"
                  ]
                }
              }
            },
            "required": [
              "sectionTitle",
              "steps"
            ]
          }
        },
        "contactFaqPreview": {
          "purpose": "Shows a few common questions on the contact page to potentially answer visitors' questions immediately without waiting for a response.",
          "dataSchema": {
            "type": "object",
            "properties": {
              "sectionTitle": {
                "type": "string",
                "description": "Heading like 'Quick Answers'"
              },
              "sectionSubtitle": {
                "type": "string",
                "description": "Brief intro, e.g. 'Before you write, check if your question is answered here'"
              },
              "questions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "question": {
                      "type": "string",
                      "description": "Common question"
                    },
                    "answer": {
                      "type": "string",
                      "description": "Brief answer, 1-3 sentences"
                    }
                  },
                  "required": [
                    "question",
                    "answer"
                  ]
                }
              },
              "faqLinkLabel": {
                "type": "string",
                "description": "Link text to full FAQ, e.g. 'View All FAQ'"
              },
              "faqLinkUrl": {
                "type": "string",
                "description": "Must be /faq"
              }
            },
            "required": [
              "sectionTitle",
              "sectionSubtitle",
              "questions",
              "faqLinkLabel",
              "faqLinkUrl"
            ]
          }
        },
        "contactClosingCta": {
          "purpose": "A brief closing section reinforcing the invitation to get in touch and linking back to the home page for visitors who want to learn more first.",
          "dataSchema": {
            "type": "object",
            "properties": {
              "headline": {
                "type": "string",
                "description": "Closing line, e.g. 'We're Here to Help You Drive Away Happy'"
              },
              "description": {
                "type": "string",
                "description": "1-2 supportive sentences"
              },
              "secondaryLinkLabel": {
                "type": "string",
                "description": "Link text, e.g. 'Back to Home'"
              },
              "secondaryLinkUrl": {
                "type": "string",
                "description": "Must be /"
              }
            },
            "required": [
              "headline",
              "description",
              "secondaryLinkLabel",
              "secondaryLinkUrl"
            ]
          }
        }
      }
    }
  }
}
